# VENTANA 1 – LOGIN
# =============================================================================
class VentanaLogin:
    """
    Ventana de inicio de sesión.
    Valida la contraseña y, si es correcta, abre la ventana de Registro.
    """

    def __init__(self):
        # ── Crear ventana raíz ────────────────────────────────────────────────
        self.root = tk.Tk()
        self.root.title("Gestión de Empleados – Acceso")
        # Ventana compacta (480x620), unificada con VentanaRegistro para
        # que ambas tengan exactamente las mismas dimensiones y una
        # apariencia uniforme y moderna en toda la aplicación.
        self.root.geometry("480x620")
        self.root.resizable(False, False)
        self.root.configure(bg=COLOR_FONDO)

        # Centrar ventana en pantalla
        self._centrar_ventana(self.root, 480, 620)

        self._construir_ui()
        self.root.mainloop()

    # ── Helpers de estilo ──────────────────────────────────────────────────────
    @staticmethod
    def _centrar_ventana(ventana, ancho, alto):
        """Calcula la posición para centrar cualquier ventana en la pantalla."""
        ventana.update_idletasks()
        x = (ventana.winfo_screenwidth() // 2) - (ancho // 2)
        y = (ventana.winfo_screenheight() // 2) - (alto // 2)
        ventana.geometry(f"{ancho}x{alto}+{x}+{y}")

    def _construir_ui(self):
        """Construye y posiciona todos los widgets del login."""

        # ── Franja superior de color acento ──────────────────────────────────
        franja = tk.Frame(self.root, bg=COLOR_ACENTO, height=6)
        franja.pack(fill="x")

        # ── Contenedor central ───────────────────────────────────────────────
        contenedor = tk.Frame(self.root, bg=COLOR_FONDO)
        contenedor.pack(expand=True, fill="both", padx=45)

        # Ícono / logotipo simbólico
        tk.Label(
            contenedor,
            text="👤",
            font=("Segoe UI", 48),
            bg=COLOR_FONDO,
            fg=COLOR_ACENTO,
        ).pack(pady=(28, 6))

        # Nombre de la aplicación
        tk.Label(
            contenedor,
            text="Gestión de Empleados",
            font=FUENTE_TITULO,
            bg=COLOR_FONDO,
            fg=COLOR_TEXTO,
        ).pack()

        # Nombre de la autora
        tk.Label(
            contenedor,
            text="Hailyen Jullieth Grajales Quiñonez",
            font=FUENTE_SUBTITULO,
            bg=COLOR_FONDO,
            fg=COLOR_ACENTO,
        ).pack(pady=(2, 0))

        tk.Label(
            contenedor,
            text="UNAD – Estructura de Datos",
            font=("Segoe UI", 9),
            bg=COLOR_FONDO,
            fg=COLOR_TEXTO_GRIS,
        ).pack(pady=(0, 3))

        # Nombre de la empresa para la que se desarrolla el sistema
        tk.Label(
            contenedor,
            text=f"Sistema desarrollado para: {NOMBRE_EMPRESA}",
            font=("Segoe UI", 9, "italic"),
            bg=COLOR_FONDO,
            fg=COLOR_TEXTO_GRIS,
        ).pack(pady=(0, 22))

        # ── Separador ────────────────────────────────────────────────────────
        tk.Frame(contenedor, bg=COLOR_BORDE, height=1).pack(fill="x", pady=(0, 14))

        # ── Label contraseña ─────────────────────────────────────────────────
        tk.Label(
            contenedor,
            text="Contraseña de acceso",
            font=FUENTE_LABEL_NEG,
            bg=COLOR_FONDO,
            fg=COLOR_TEXTO_GRIS,
            anchor="w",
        ).pack(fill="x")

        # ── Campo de contraseña (enmascarado) ────────────────────────────────
        self.entrada_password = tk.Entry(
            contenedor,
            show="●",                    # máscara con puntos
            font=("Segoe UI", 13),
            bg=COLOR_ENTRADA,
            fg=COLOR_TEXTO,
            insertbackground=COLOR_ACENTO,
            relief="flat",
            bd=0,
        )
        self.entrada_password.pack(fill="x", ipady=8, pady=(6, 4))

        # Línea decorativa debajo del entry
        tk.Frame(contenedor, bg=COLOR_ACENTO, height=2).pack(fill="x")

        # Permite presionar Enter como alternativa al botón
        self.entrada_password.bind("<Return>", lambda e: self._verificar_password())

        # ── Botón Ingresar ───────────────────────────────────────────────────
        btn = tk.Button(
            contenedor,
            text="  INGRESAR  →",
            font=FUENTE_BTN,
            bg=COLOR_BTN_PPAL,
            fg="#0D1F2D",
            activebackground=COLOR_BTN_HOVER,
            activeforeground="#0D1F2D",
            relief="flat",
            cursor="hand2",
            command=self._verificar_password,
        )
        btn.pack(fill="x", ipady=10, pady=(16, 0))

        # ── Poner foco en el campo de contraseña ─────────────────────────────
        self.entrada_password.focus_set()

    def _verificar_password(self):
        """
        Lee la contraseña ingresada y la compara con la contraseña genérica.
        - Correcta → cierra esta ventana y abre VentanaRegistro.
        - Incorrecta → muestra un messagebox de error y limpia el campo.
        """
        password_ingresada = self.entrada_password.get()

        if password_ingresada == CONTRASEÑA_CORRECTA:
            # ── Éxito: cierra login y abre registro ──────────────────────────
            self.root.destroy()
            VentanaRegistro()
        else:
            # ── Error: avisa al usuario y limpia el campo ─────────────────────
            messagebox.showerror(
                "Acceso denegado",
                "Contraseña incorrecta.\nPor favor inténtelo de nuevo.",
            )
            self.entrada_password.delete(0, tk.END)
            self.entrada_password.focus_set()


