# VENTANA 2 – REGISTRO DE DATOS DEL EMPLEADO
# =============================================================================
class VentanaRegistro:
    """
    Formulario principal para ingresar los datos del empleado.
    Instancia la clase GestionEmpleados al guardar y abre el reporte.
    """

    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Gestión de Empleados – Registro")
        # Alto aumentado de 670 a 760: con 670px el botón
        # "Calcular Nómina / Mostrar Reporte" y "Salir" quedaban
        # parcialmente cortados en la parte inferior de la ventana.
        self.root.geometry("480x620")
        self.root.resizable(False, False)
        self.root.configure(bg=COLOR_FONDO)

        # Objeto empleado – se instancia al presionar "Guardar Registro"
        self.empleado: GestionEmpleados | None = None

        # Contador automático de filas del grid: cada widget que se agregue
        # al formulario consume su propio bloque de filas y avanza este
        # contador, evitando que dos controles terminen en la misma fila
        # (causa raíz de la superposición de Entry/Label detectada).
        self._fila_actual = 0

        # Interceptar el botón "X" de la ventana para pedir confirmación,
        # igual que el botón "Salir" (evita cierres accidentales).
        self.root.protocol("WM_DELETE_WINDOW", self._confirmar_salida)

        # ── Validadores de entrada en tiempo real ───────────────────────────
        # Tkinter exige registrar cada función de validación contra la
        # ventana antes de poder asignarla a un Entry mediante
        # validatecommand. Esto bloquea el carácter en el momento en que
        # se escribe (no solo al guardar), corrigiendo los problemas 1, 2 y 3.
        self._validador_numerico = self.root.register(self._validar_solo_numeros)
        self._validador_nombre   = self.root.register(self._validar_solo_letras)

        VentanaLogin._centrar_ventana(self.root, 480, 620)
        self._construir_ui()
        self.root.mainloop()

    # ── Funciones de validación de caracteres ───────────────────────────────────
    @staticmethod
    def _validar_solo_numeros(texto_propuesto: str) -> bool:
        """
        Valida en tiempo real que el contenido propuesto para un Entry
        sea únicamente numérico. Se usa en Identificación y Días Laborados
        (Problemas 1 y 2). Permite el campo vacío para poder borrar todo
        el contenido sin quedar bloqueado.
        """
        if texto_propuesto == "":
            return True
        return texto_propuesto.isdigit()

    @staticmethod
    def _validar_solo_letras(texto_propuesto: str) -> bool:
        """
        Valida en tiempo real que el contenido propuesto para el Entry de
        Nombre Completo contenga únicamente letras (incluye tildes, Ñ/ñ
        y diéresis propias del español), espacios, y apóstrofo (para
        nombres compuestos como O'Higgins). Corrige el Problema 3.
        """
        if texto_propuesto == "":
            return True
        caracteres_permitidos = (
            "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
            "áéíóúÁÉÍÓÚñÑüÜ "
        )
        return all(caracter in caracteres_permitidos for caracter in texto_propuesto)

    # ── Constructor de la interfaz ─────────────────────────────────────────────
    def _construir_ui(self):
        """Construye todos los widgets del formulario de registro."""

        # ── Franja superior ───────────────────────────────────────────────────
        tk.Frame(self.root, bg=COLOR_ACENTO, height=6).pack(fill="x")

        # ── Encabezado ────────────────────────────────────────────────────────
        encabezado = tk.Frame(self.root, bg=COLOR_PANEL, pady=14)
        encabezado.pack(fill="x", padx=0)

        tk.Label(
            encabezado,
            text="📋  Registro de Empleado",
            font=FUENTE_TITULO,
            bg=COLOR_PANEL,
            fg=COLOR_TEXTO,
        ).pack()

        tk.Label(
            encabezado,
            text="Complete todos los campos y guarde el registro",
            font=FUENTE_SUBTITULO,
            bg=COLOR_PANEL,
            fg=COLOR_TEXTO_GRIS,
        ).pack()

        # ── Área de formulario con scroll ─────────────────────────────────────
        # Usamos un Frame con padding para agrupar los campos
        form = tk.Frame(self.root, bg=COLOR_FONDO, padx=24, pady=6)
        form.pack(fill="both", expand=True)

        # ── Campo: Identificación ────────────────────────────────────────────
        # _crear_campo() avanza el contador self._fila_actual automáticamente,
        # por lo que ningún widget puede terminar compartiendo fila con otro.
        # Se le pasa el validador numérico para que solo acepte dígitos
        # mientras se escribe (corrige el Problema 1).
        self.entrada_id = self._crear_campo(
            form, "Número de Identificación", validador=self._validador_numerico
        )

        # ── Campo: Nombre Completo ───────────────────────────────────────────
        # Se le pasa el validador alfabético para que solo acepte letras,
        # espacios y tildes mientras se escribe (corrige el Problema 3).
        self.entrada_nombre = self._crear_campo(
            form, "Nombre Completo", validador=self._validador_nombre
        )

        # ── Campo: Género (Radio Buttons) ─────────────────────────────────────
        self._label_campo(form, "Género")

        self.var_genero = tk.StringVar(value="Masculino")

        frame_radio = tk.Frame(form, bg=COLOR_FONDO)
        frame_radio.grid(row=self._fila_actual, column=0, columnspan=2, sticky="w", pady=(0, 5))
        self._fila_actual += 1

        for opcion in ("Masculino", "Femenino"):
            tk.Radiobutton(
                frame_radio,
                text=opcion,
                variable=self.var_genero,
                value=opcion,
                font=FUENTE_LABEL,
                bg=COLOR_FONDO,
                fg=COLOR_TEXTO,
                selectcolor=COLOR_ENTRADA,
                activebackground=COLOR_FONDO,
                activeforeground=COLOR_ACENTO,
                cursor="hand2",
            ).pack(side="left", padx=(0, 20))

        # ── Campo: Cargo Laboral (Combobox) ───────────────────────────────────
        self._label_campo(form, "Cargo Laboral")

        # Estilo del Combobox via ttk.Style
        estilo = ttk.Style()
        estilo.theme_use("clam")
        estilo.configure(
            "Custom.TCombobox",
            fieldbackground=COLOR_ENTRADA,
            background=COLOR_ENTRADA,
            foreground=COLOR_TEXTO,
            selectbackground=COLOR_ACENTO,
            selectforeground="#0D1F2D",
            arrowcolor=COLOR_ACENTO,
            bordercolor=COLOR_BORDE,
            lightcolor=COLOR_BORDE,
            darkcolor=COLOR_BORDE,
        )

        self.var_cargo = tk.StringVar()
        self.combo_cargo = ttk.Combobox(
            form,
            textvariable=self.var_cargo,
            values=list(SALARIOS_CARGO.keys()),
            state="readonly",
            font=FUENTE_ENTRADA,
            style="Custom.TCombobox",
        )
        self.combo_cargo.grid(row=self._fila_actual, column=0, columnspan=2, sticky="ew", pady=(0, 5), ipady=4)
        self._fila_actual += 1
        # Cuando cambia el cargo, actualiza automáticamente el salario
        self.combo_cargo.bind("<<ComboboxSelected>>", self._actualizar_salario)

        # ── Campo: Salario Día (deshabilitado, solo lectura) ─────────────────
        self._label_campo(form, "Salario por Día (COP $)")

        self.var_salario = tk.StringVar(value="Seleccione un cargo primero")
        self.entrada_salario = tk.Entry(
            form,
            textvariable=self.var_salario,
            font=FUENTE_ENTRADA,
            bg=COLOR_PANEL,          # fondo diferente para indicar que es de solo lectura
            fg=COLOR_ACENTO,
            disabledforeground=COLOR_ACENTO,
            disabledbackground=COLOR_PANEL,
            relief="flat",
            state="disabled",        # ← completamente deshabilitado
        )
        self.entrada_salario.grid(row=self._fila_actual, column=0, columnspan=2, sticky="ew", ipady=5, pady=(0, 5))
        self._fila_actual += 1
        tk.Frame(form, bg=COLOR_BORDE, height=1).grid(
            row=self._fila_actual, column=0, columnspan=2, sticky="ew", pady=(0, 5)
        )
        self._fila_actual += 1

        # ── Campo: Días Laborados ─────────────────────────────────────────────
        # Se le pasa el validador numérico para que solo acepte dígitos
        # mientras se escribe (corrige el Problema 2).
        self.entrada_dias = self._crear_campo(
            form, "Días Laborados", validador=self._validador_numerico
        )

        # Configurar columnas del grid para que los entry se expandan
        form.columnconfigure(0, weight=1)
        form.columnconfigure(1, weight=1)

        # ── Barra de botones ──────────────────────────────────────────────────
        barra = tk.Frame(self.root, bg=COLOR_PANEL, pady=6, padx=24)
        barra.pack(fill="x", side="bottom")

        # Botón Guardar Registro
        self._btn(
            barra,
            texto="💾  Guardar Registro",
            comando=self._guardar_registro,
            color=COLOR_BTN_PPAL,
            fg_color="#0D1F2D",
        ).pack(fill="x", ipady=6, pady=(0, 4))

        # Botón Calcular Nómina / Mostrar Reporte
        self._btn(
            barra,
            texto="📊  Calcular Nómina / Mostrar Reporte",
            comando=self._mostrar_reporte,
            color=COLOR_ACENTO2,
            fg_color=COLOR_TEXTO,
        ).pack(fill="x", ipady=6, pady=(0, 4))

        # Botón Salir
        self._btn(
            barra,
            texto="✖  Salir",
            comando=self._confirmar_salida,
            color=COLOR_BTN_SALIR,
            fg_color=COLOR_TEXTO,
        ).pack(fill="x", ipady=6)

    # ── Métodos de ayuda para construir widgets ────────────────────────────────
    def _label_campo(self, parent, texto):
        """
        Crea una etiqueta de campo en la siguiente fila disponible del grid
        y avanza automáticamente el contador self._fila_actual.
        """
        tk.Label(
            parent,
            text=texto,
            font=FUENTE_LABEL_NEG,
            bg=COLOR_FONDO,
            fg=COLOR_TEXTO_GRIS,
            anchor="w",
        ).grid(row=self._fila_actual, column=0, columnspan=2, sticky="w", pady=(3, 0))
        self._fila_actual += 1

    def _crear_campo(self, parent, etiqueta, validador=None):
        """
        Crea una etiqueta + Entry (en filas consecutivas calculadas
        automáticamente con self._fila_actual) y retorna el Entry para
        su uso posterior. Esta versión elimina el riesgo de superposición
        de widgets que existía cuando las filas se calculaban a mano
        (row, row+1, row+2) y no coincidían con el avance real del
        formulario, causando que campos como "Nombre Completo" quedaran
        dibujados encima de "Identificación" y no respondieran al clic.

        Parameters
        ----------
        validador : tupla opcional (nombre_tcl, ) devuelta por root.register().
                    Si se pasa, el Entry queda restringido en tiempo real a
                    aceptar solo los caracteres que la función de validación
                    permita (ver _validar_solo_numeros / _validar_solo_letras).
        """
        self._label_campo(parent, etiqueta)

        entry = tk.Entry(
            parent,
            font=FUENTE_ENTRADA,
            bg=COLOR_ENTRADA,
            fg=COLOR_TEXTO,
            insertbackground=COLOR_ACENTO,
            relief="flat",
        )

        # Si se proporcionó un validador, se vincula al Entry.
        # validate="key" dispara la validación en cada pulsación de tecla.
        # %P es el código de sustitución de Tcl/Tk que representa el texto
        # COMPLETO que tendría el campo si la tecla se llegara a aceptar.
        if validador is not None:
            entry.config(validate="key", validatecommand=(validador, "%P"))

        entry.grid(row=self._fila_actual, column=0, columnspan=2, sticky="ew", ipady=5, pady=(1, 0))
        self._fila_actual += 1

        # Línea decorativa
        tk.Frame(parent, bg=COLOR_BORDE, height=1).grid(
            row=self._fila_actual, column=0, columnspan=2, sticky="ew", pady=(0, 3)
        )
        self._fila_actual += 1

        return entry

    @staticmethod
    def _btn(parent, texto, comando, color, fg_color):
        """Crea y devuelve un botón con estilo uniforme."""
        return tk.Button(
            parent,
            text=texto,
            font=FUENTE_BTN,
            bg=color,
            fg=fg_color,
            activebackground=COLOR_BTN_HOVER,
            activeforeground=fg_color,
            relief="flat",
            cursor="hand2",
            command=comando,
        )

    # ── Lógica de eventos ──────────────────────────────────────────────────────
    def _actualizar_salario(self, event=None):
        """
        Se dispara al cambiar el Combobox de cargo.
        Habilita temporalmente el Entry de salario para escribir el valor,
        luego lo vuelve a deshabilitar.
        """
        cargo = self.var_cargo.get()
        salario = SALARIOS_CARGO.get(cargo, 0.0)

        # Habilitar brevemente para actualizar el valor
        self.entrada_salario.config(state="normal")
        self.var_salario.set(f"$ {salario:,.0f}")
        self.entrada_salario.config(state="disabled")

    def _guardar_registro(self):
        """
        Valida los campos y, si todo es correcto, instancia GestionEmpleados
        guardando la fecha/hora actual en fecha_registro.
        """
        # ── Validaciones básicas ──────────────────────────────────────────────
        identificacion  = self.entrada_id.get().strip()
        nombre_completo = self.entrada_nombre.get().strip()
        genero          = self.var_genero.get()
        cargo_laboral   = self.var_cargo.get()
        dias_txt        = self.entrada_dias.get().strip()

        if not identificacion:
            messagebox.showwarning("Campo requerido", "Ingrese la identificación del empleado.")
            self.entrada_id.focus_set()
            return

        # Validación: la identificación debe ser solo numérica (cédula/documento)
        if not identificacion.isdigit():
            messagebox.showerror(
                "Valor inválido",
                "La identificación debe contener únicamente números.",
            )
            self.entrada_id.focus_set()
            return

        if not nombre_completo:
            messagebox.showwarning("Campo requerido", "Ingrese el nombre completo del empleado.")
            self.entrada_nombre.focus_set()
            return

        if not cargo_laboral:
            messagebox.showwarning("Campo requerido", "Seleccione el cargo laboral.")
            self.combo_cargo.focus_set()
            return

        if not dias_txt:
            messagebox.showwarning("Campo requerido", "Ingrese los días laborados.")
            self.entrada_dias.focus_set()
            return

        try:
            dias_laborados = int(dias_txt)
            if dias_laborados <= 0:
                raise ValueError
            # Validación de rango: un mes tiene máximo 31 días;
            # se permite hasta 31 para cubrir un período mensual completo.
            if dias_laborados > 31:
                messagebox.showerror(
                    "Valor inválido",
                    "Los días laborados no pueden ser mayores a 31 (un mes).",
                )
                self.entrada_dias.focus_set()
                return
        except ValueError:
            messagebox.showerror("Valor inválido", "Los días laborados deben ser un número entero positivo.")
            self.entrada_dias.focus_set()
            return

        salario_dia = SALARIOS_CARGO[cargo_laboral]

        # ── Instanciar la clase de lógica con la fecha/hora actual ─────────────
        self.empleado = GestionEmpleados(
            identificacion  = identificacion,
            nombre_completo = nombre_completo,
            genero          = genero,
            cargo_laboral   = cargo_laboral,
            salario_dia     = salario_dia,
            dias_laborados  = dias_laborados,
            fecha_registro  = datetime.now(),   # ← captura automática
        )

        messagebox.showinfo(
            "Registro exitoso",
            f"Los datos de {nombre_completo} han sido guardados correctamente.\n\n"
            f"Fecha de registro: {self.empleado.fecha_registro.strftime('%d/%m/%Y %H:%M:%S')}",
        )

    def _mostrar_reporte(self):
        """
        Abre la VentanaReporte si hay un empleado registrado;
        de lo contrario, avisa al usuario.
        """
        if self.empleado is None:
            messagebox.showwarning(
                "Sin datos",
                "Primero debe guardar el registro del empleado\nantes de generar el reporte.",
            )
            return

        # Abrir el reporte como ventana hija (Toplevel)
        VentanaReporte(parent=self, empleado=self.empleado)

    def _confirmar_salida(self):
        """Muestra un cuadro de diálogo de confirmación antes de cerrar."""
        respuesta = messagebox.askyesno(
            "Confirmar cierre",
            "¿Está seguro de que desea cerrar la aplicación?\n"
            "Los datos no guardados se perderán.",
        )
        if respuesta:
            self.root.destroy()

    def limpiar_formulario(self):
        """
        Limpia todos los campos del formulario de Registro y reinicia
        self.empleado a None. Se invoca desde VentanaReporte al presionar
        "Regresar", para dejar la interfaz lista para un nuevo registro.
        """
        self.entrada_id.delete(0, tk.END)
        self.entrada_nombre.delete(0, tk.END)
        self.entrada_dias.delete(0, tk.END)

        self.var_genero.set("Masculino")
        self.var_cargo.set("")

        self.entrada_salario.config(state="normal")
        self.var_salario.set("Seleccione un cargo primero")
        self.entrada_salario.config(state="disabled")

        self.empleado = None
        self.entrada_id.focus_set()


# =============================================================================
# VENTANA 3 – REPORTE / NÓMINA
# =============================================================================
class VentanaReporte:
    """
    Ventana Toplevel que muestra el reporte completo del empleado registrado
    y calcula el total a pagar usando el método de la clase GestionEmpleados.
    """

    def __init__(self, parent, empleado: GestionEmpleados):
        self.empleado = empleado
        # 'parent' es la instancia de VentanaRegistro (no solo su root),
        # lo que permite invocar limpiar_formulario() al regresar.
        self.ventana_registro = parent
        self.parent = parent.root

        # ── Crear ventana hija ─────────────────────────────────────────────────
        self.ventana = tk.Toplevel(self.parent)
        self.ventana.title("Reporte de Nómina")
        self.ventana.geometry("500x660")
        self.ventana.resizable(False, False)
        self.ventana.configure(bg=COLOR_FONDO)
        self.ventana.grab_set()   # Bloquea interacción con la ventana padre mientras está abierta

        # IMPORTANTE: si el reporte se cierra con la "X" del sistema operativo
        # (en vez del botón "Regresar"), nos asegura liberar el grab_set y
        # devolver el foco al formulario de Registro. Sin esto, los campos
        # de Nombre/Género/Días podrían quedar bloqueados.
        self.ventana.protocol("WM_DELETE_WINDOW", self._cerrar)

        VentanaLogin._centrar_ventana(self.ventana, 500, 660)
        self._construir_ui()

    def _cerrar(self):
        """
        Libera el grab_set, destruye la ventana de reporte, limpia el
        formulario de Registro (identificación, nombre, días laborados,
        salario, género y cargo restablecidos a sus valores por defecto)
        y devuelve el foco a la ventana de Registro.
        """
        self.ventana.grab_release()
        self.ventana.destroy()
        self.ventana_registro.limpiar_formulario()
        self.parent.focus_force()

    def _construir_ui(self):
        """Construye el reporte visual con todos los datos del empleado."""

        # ── Franja superior ───────────────────────────────────────────────────
        tk.Frame(self.ventana, bg=COLOR_ACENTO, height=6).pack(fill="x")

        # ── Encabezado ─────────────────────────────────────────────────────────
        enc = tk.Frame(self.ventana, bg=COLOR_PANEL, pady=16)
        enc.pack(fill="x")

        tk.Label(enc, text="📄  Reporte de Nómina", font=FUENTE_TITULO, bg=COLOR_PANEL, fg=COLOR_TEXTO).pack()
        tk.Label(
            enc,
            text=NOMBRE_EMPRESA,
            font=("Segoe UI", 10, "bold"),
            bg=COLOR_PANEL,
            fg=COLOR_ACENTO,
        ).pack()
        tk.Label(
            enc,
            text=f"Generado el {datetime.now().strftime('%d/%m/%Y  %H:%M:%S')}",
            font=("Segoe UI", 9),
            bg=COLOR_PANEL,
            fg=COLOR_TEXTO_GRIS,
        ).pack()

        # ── Botón Regresar ─────────────────────────────────────────────────────
        # IMPORTANTE: este botón se empaqueta con side="bottom" ANTES de
        # crear el panel de datos (que usa expand=True). En Tkinter, el
        # gestor pack() reserva primero el espacio de los widgets ya
        # empaquetados; al colocar el botón antes y anclado al fondo, se
        # le garantiza su espacio fijo en la ventana sin que el contenido
        # variable del panel lo empuje fuera del área visible o lo deje
        # viéndose delgado/cortado. Altura interna aumentada (ipady=16) y
        # mayor margen respecto al borde inferior (pady=28), para que el
        # botón tenga una presencia visual robusta y uniforme con los
        # botones de la ventana de Registro (Guardar Registro, Calcular
        # Nómina, Salir), sin modificar su color, texto ni funcionalidad.
        tk.Button(
            self.ventana,
            text="← Regresar",
            font=FUENTE_BTN,
            bg=COLOR_ACENTO2,
            fg=COLOR_TEXTO,
            activebackground="#0062AD",
            relief="flat",
            cursor="hand2",
            command=self._cerrar,
        ).pack(side="bottom", fill="x", padx=20, pady=(10, 28), ipady=16)

        # ── Panel de datos ─────────────────────────────────────────────────────
        panel = tk.Frame(self.ventana, bg=COLOR_PANEL, padx=28, pady=20)
        panel.pack(fill="both", expand=True, padx=20, pady=12)

        # Calcular el total usando el método de la clase de lógica
        # Llamado explícito con cargo y costo por día como parámetros,
        # tal como lo exige el Anexo 2 de la guía UNAD.
        total_pagar = self.empleado.calcular_total_pago(
            cargo_laboral=self.empleado.cargo_laboral,
            salario_dia=self.empleado.salario_dia,
        )

        # Lista de (etiqueta, valor) para mostrar ordenadamente
        campos = [
            ("Identificación",     self.empleado.identificacion),
            ("Nombre Completo",    self.empleado.nombre_completo),
            ("Género",             self.empleado.genero),
            ("Cargo Laboral",      self.empleado.cargo_laboral),
            ("Días Laborados",     str(self.empleado.dias_laborados)),
            ("Valor por Día",      f"$ {self.empleado.salario_dia:,.0f}"),
            ("Fecha de Registro",  self.empleado.fecha_registro.strftime("%d/%m/%Y  %H:%M:%S")),
        ]

        for i, (etiqueta, valor) in enumerate(campos):
            # Fila con color alternado para legibilidad
            color_fila = COLOR_ENTRADA if i % 2 == 0 else COLOR_PANEL
            fila = tk.Frame(panel, bg=color_fila, pady=5, padx=10)
            fila.pack(fill="x", pady=1)

            tk.Label(
                fila,
                text=etiqueta,
                font=FUENTE_LABEL_NEG,
                bg=color_fila,
                fg=COLOR_TEXTO_GRIS,
                width=18,
                anchor="w",
            ).pack(side="left")

            tk.Label(
                fila,
                text=valor,
                font=FUENTE_REPORTE,
                bg=color_fila,
                fg=COLOR_TEXTO,
                anchor="w",
            ).pack(side="left", padx=(10, 0))

        # ── Separador antes del total ──────────────────────────────────────────
        tk.Frame(panel, bg=COLOR_ACENTO, height=2).pack(fill="x", pady=(14, 10))

        # ── Total a Pagar (destacado) ─────────────────────────────────────────
        fila_total = tk.Frame(panel, bg=COLOR_PANEL, pady=8, padx=10)
        fila_total.pack(fill="x")

        tk.Label(
            fila_total,
            text="TOTAL A PAGAR",
            font=FUENTE_TOTAL,
            bg=COLOR_PANEL,
            fg=COLOR_ACENTO,
        ).pack(side="left")

        tk.Label(
            fila_total,
            text=f"$ {total_pagar:,.0f}",
            font=FUENTE_TOTAL,
            bg=COLOR_PANEL,
            fg=COLOR_TEXTO,
        ).pack(side="right")

        # ── Nota de cálculo ────────────────────────────────────────────────────
        tk.Label(
            panel,
            text=f"Cálculo: ${self.empleado.salario_dia:,.0f}/día  ×  {self.empleado.dias_laborados} días",
            font=("Segoe UI", 9, "italic"),
            bg=COLOR_PANEL,
            fg=COLOR_TEXTO_GRIS,
        ).pack(pady=(4, 0))


