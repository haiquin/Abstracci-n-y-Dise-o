# CLASE DE LÓGICA: GestionEmpleados
# Representa la entidad de negocio "Empleado" y su lógica de cálculo.
# =============================================================================
class GestionEmpleados:
    """
    Clase pública que modela la información y la lógica de pago de un empleado.

    Atributos
    ---------
    identificacion   : str      – Número de documento del empleado.
    nombre_completo  : str      – Nombre y apellidos completos.
    genero           : str      – 'Masculino' o 'Femenino'.
    cargo_laboral    : str      – Cargo seleccionado en la empresa.
    salario_dia      : float    – Valor del salario por día según cargo.
    dias_laborados   : int      – Cantidad de días trabajados en el período.
    fecha_registro   : datetime – Fecha/hora en que se registró el empleado.
    """

    def __init__(
        self,
        identificacion: str,
        nombre_completo: str,
        genero: str,
        cargo_laboral: str,
        salario_dia: float,
        dias_laborados: int,
        fecha_registro: datetime,
    ):
        self.identificacion = identificacion
        self.nombre_completo = nombre_completo
        self.genero = genero
        self.cargo_laboral = cargo_laboral
        self.salario_dia = salario_dia
        self.dias_laborados = dias_laborados
        self.fecha_registro = fecha_registro

    def calcular_total_pago(self, cargo_laboral: str = None, salario_dia: float = None) -> float:
        """
        Calcula el total a pagar al empleado.

        Según el Anexo 2 de la guía UNAD, el método recibe como parámetros
        el cargo y el costo por día trabajado. Si no se especifican,
        el método usa los valores ya almacenados en la instancia
        (cargo_laboral y salario_dia), lo cual permite tanto la firma
        exigida por la guía como un uso simplificado sin repetir datos.

        Parameters
        ----------
        cargo_laboral : str, opcional – Cargo del empleado (informativo).
        salario_dia    : float, opcional – Valor del salario por día.
                          Si se proporciona, sobrescribe el ya almacenado.

        Fórmula: total = salario_dia × dias_laborados

        Returns
        -------
        float – Valor total de la nómina para el período.
        """
        # Si el llamado incluye el cargo, se valida coherencia con el registro
        if cargo_laboral is not None:
            self.cargo_laboral = cargo_laboral

        # Si se especifica un salario por día distinto, se actualiza
        if salario_dia is not None:
            self.salario_dia = salario_dia

        return self.salario_dia * self.dias_laborados


